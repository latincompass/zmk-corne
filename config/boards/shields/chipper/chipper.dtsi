#include <dt-bindings/zmk/matrix_transform.h>

/ {
	chosen {
		zmk,kscan = &kscan0;
		zmk,matrix_transform = &default_transform;
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <6>;
		rows = <4>;
		map = <
		RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
		RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
		RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
		         RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
		>;
	};

	kscan0: kscan {
		compatible = "zmk,gpio-matrix";
		label = "KSCAN";
		diode-direction = "col2row";

		// ======================
		// 行 ROW → 你焊的 D0~D3
		// ======================
		row-gpios
			= <&gpio0  2 GPIO_ACTIVE_HIGH>  // ROW0 → D0
			, <&gpio0  3 GPIO_ACTIVE_HIGH>  // ROW1 → D1
			, <&gpio0 28 GPIO_ACTIVE_HIGH>  // ROW2 → D2
			, <&gpio0 29 GPIO_ACTIVE_HIGH>  // ROW3 → D3
			;

		// ======================
		// 列 COL → 你焊的 D4~D9
		// ======================
		col-gpios
			= <&gpio0  4 GPIO_ACTIVE_HIGH>  // COL0 → D4
			, <&gpio0  5 GPIO_ACTIVE_HIGH>  // COL1 → D5
			, <&gpio1 11 GPIO_ACTIVE_HIGH>  // COL2 → D6
			, <&gpio1 12 GPIO_ACTIVE_HIGH>  // COL3 → D7
			, <&gpio1 13 GPIO_ACTIVE_HIGH>  // COL4 → D8
			, <&gpio1 14 GPIO_ACTIVE_HIGH>  // COL5 → D9
			;
	};
};
